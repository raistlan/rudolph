# Copy to rudolph/.env and fill in. rudolph/.env is gitignored — never commit it.

# Cursor Cloud Agents API key, from https://cursor.com/dashboard/api
# Used by bin/rudolph-cursor-e2e (phase 7) to launch the E2E cloud agent.
CURSOR_API_KEY=

# Optional overrides:
# RUDOLPH_REPO_URL=https://github.com/your-org/your-repo
# RUDOLPH_CURSOR_MODEL=composer-2
